{
  "git": {
    "commit": true,
    "commitMessage": "chore: bump to ${version}",
    "tagName": "v${version}",
    "tag": true,
    "push": true
  },
  "github": { "release": false },
  "npm": { "publish": false },
  "hooks": {
    "after:bump": "node scripts/update-npx-pin.mjs ${version} && npm run build"
  }
}
